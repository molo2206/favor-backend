<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="utf-8">
  <title>Facture</title>
  <style>
    /* Ajoute ici tes styles CSS pour la facture */
  </style>
</head>
<body>
  <div class="section">
    <div class="section-title">Détails de la facture / Invoice Details</div>
    <table border="1" cellpadding="5" cellspacing="0" width="100%">
      <thead>
        <tr>
          <th>N°</th>
          <th>Produit</th>
          <th>Quantité</th>
          <th>Prix unitaire</th>
          <th>Total</th>
        </tr>
      </thead>
      <tbody>
        <!-- Inclusion des détails des sous-commandes -->
        <%- subOrdersHtml %>

      </tbody>
      <tfoot>
        <tr>
          <td colspan="4" style="text-align: right"><strong>Sous-total:</strong></td>
          <td><%= order.subTotal %> <%= order.currency %></td>
        </tr>
        <tr>
          <td colspan="4" style="text-align: right">Frais de livraison:</td>
          <td><%= order.shippingFee %> <%= order.currency %></td>
        </tr>
        <tr>
          <td colspan="4" style="text-align: right">Frais de douane:</td>
          <td><%= order.customsFee %> <%= order.currency %></td>
        </tr>
        <tr>
          <td colspan="4" style="text-align: right">Remise:</td>
          <td>-<%= order.discount %> <%= order.currency %></td>
        </tr>
        <tr>
          <td colspan="4" style="text-align: right">TVA:</td>
          <td><%= order.tax %> <%= order.currency %></td>
        </tr>
        <tr>
          <td colspan="4" style="text-align: right"><strong>Total:</strong></td>
          <td><strong><%= order.totalAmount %> <%= order.currency %></strong></td>
        </tr>
      </tfoot>
    </table>
  </div>
</body>
</html>
